{
  "name": "xay-dung-phan-mem-web-nhom-1-chieu-thu-3",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.16",
    "typescript": "5.9.2",
    "vite": "^6.0.0"
  },
  "overrides": {
    "vite": "$vite"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "apps/web-app/**/*.{ts,tsx}": [
      "eslint --fix --config apps/web-app/eslint.config.js",
      "npx vitest related --run --root apps/web-app"
    ],
    "apps/api/**/*.php": [
      "php ./apps/api/vendor/bin/pint"
    ],
    "apps/api/tests/**/*.php": [
      "php ./apps/api/vendor/bin/phpunit -c ./apps/api/phpunit.xml"
    ]
  }
}

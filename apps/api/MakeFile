# Biến nhận tham số
name ?=

# --- Development Commands ---
# Dùng khi dev ngoài Docker, debug nhanh

# Chạy server Laravel
serve:
	php artisan serve

# Đồng bộ Database
migrate:
	php artisan migrate

# Làm mới toàn bộ dữ liệu (Cẩn thận khi chạy lệnh này)
fresh:
	php artisan migrate:fresh --seed
clear:
	php artisan config:clear
	php artisan route:clear
	php artisan event:clear
	php artisan view:clear
	php artisan cache:clear
# --- GENERATOR COMMANDS ---

# Lệnh tổng hợp: tạo full bộ khung API
# Cách dùng: make api name=ModelName
api:
	@echo "Init module: $(name)..."
	php artisan make:model $(name) -m
	php artisan make:controller $(name)/$(name)Controller --api
	@make request-set name=$(name)
	@make resource-set name=$(name)
	@if not exist "app\Services\$(name)" mkdir "app\Services\$(name)"
	@if not exist "app\Services\$(name)\$(name)Service.php" ( \
		echo ^<?php > "app\Services\$(name)\$(name)Service.php" && \
		echo. >> "app\Services\$(name)\$(name)Service.php" && \
		echo namespace App\Services\$(name); >> "app\Services\$(name)\$(name)Service.php" && \
		echo. >> "app\Services\$(name)\$(name)Service.php" && \
		echo class $(name)Service >> "app\Services\$(name)\$(name)Service.php" && \
		echo { >> "app\Services\$(name)\$(name)Service.php" && \
		echo     // Logic for $(name) here >> "app\Services\$(name)\$(name)Service.php" && \
		echo } >> "app\Services\$(name)\$(name)Service.php" \
	)
	@echo Done. Check at app/Services/$(name) and Route.

# --- SUB-COMMANDS ---

request-set:
	php artisan make:request $(name)/Store$(name)Request
	php artisan make:request $(name)/Update$(name)Request

resource-set:
	php artisan make:resource $(name)/$(name)Resource
	php artisan make:resource $(name)/$(name)Collection

test:
	php artisan test